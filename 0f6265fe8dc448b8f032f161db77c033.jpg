/* CSS for the form */
body {
    font-family: Arial, sans-serif;
    background-color: #f4f4f4;
    margin: 0;
    padding: 20px;
}
.form-container {
    max-width: 800px;
    margin: auto;
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    border: 2px solid #000; /* Black border for form container */
}
h2 {
    color: #000; /* Black color for header */
    text-align: center;
    margin-bottom: 20px;
}
.section {
    margin-bottom: 20px;
}
.section h3 {
    margin-bottom: 10px;
    font-size: 1.2em;
    color: #d32f2f; /* Red color for section headers */
    border-bottom: 2px solid #d32f2f; /* Red underline for section headers */
    padding-bottom: 5px;
}
.form-group {
    margin-bottom: 15px;
}
.form-group label {
    display: block;
    font-weight: bold;
    margin-bottom: 5px;
    color: #333; /* Dark gray color for labels */
}
.form-group input,
.form-group textarea {
    width: 100%;
    padding: 8px;
    border: 1px solid #ddd; /* Light gray border */
    border-radius: 4px;
    box-sizing: border-box;
    background: #fff; /* White background for input fields */
}
.form-group input:focus,
.form-group textarea:focus {
    border-color: #d32f2f; /* Red border color on focus */
    outline: none; /* Remove default outline */
}
.form-group textarea {
    resize: vertical;
}
.button-group {
    text-align: right;
}
.button-group button {
    padding: 10px 15px;
    border: none;
    border-radius: 4px;
    color: #fff;
    background-color: #d32f2f; /* Red background color for button */
    cursor: pointer;
    font-size: 16px;
}
.button-group button:hover {
    background-color: #b71c1c; /* Darker red on hover */
}
